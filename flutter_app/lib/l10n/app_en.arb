  "rulesSkTrumpTitle": "Black suit = Trump",
  "rulesSkTrumpBody": "Black number cards beat all other suit number cards regardless of number. However, you must follow the lead suit (the suit of the first number card) if you can, and may only play black when you have no cards of the led suit.",

  "rulesSkSpecialTitle": "Special Card Rules",
  "rulesSkSpecialEscapeTitle": "Escape",
  "rulesSkSpecialEscapeLine1": "Never wins a trick. Can be played at any time regardless of suit following.",
  "rulesSkSpecialEscapeLine2": "If all players play only Escapes, the lead player takes the trick.",
  "rulesSkSpecialPirateTitle": "Pirate",
